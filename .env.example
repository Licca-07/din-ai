# OpenAI API キー（https://platform.openai.com/api-keys で取得）
OPENAI_API_KEY=sk-your-api-key-here

# チャットモデル（自動ルーティング）
# 軽い会話: OPENAI_MODEL_MINI / 調査・比較: OPENAI_MODEL_PRO
OPENAI_MODEL_MINI=gpt-4o-mini
OPENAI_MODEL_PRO=gpt-4.1

# research mode 閾値（標準 5、会話性重視なら 6）
# RESEARCH_MODE_THRESHOLD=5

# 後方互換（OPENAI_MODEL_MINI 未設定時のフォールバック）
OPENAI_MODEL=gpt-4o-mini

# Supabase（記憶の同期）
# https://supabase.com/dashboard の Project Settings > API から取得
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push（ロック画面通知用）
# node scripts/generate-vapid-keys.mjs で生成
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# Vercel Cron 認証（Vercel が自動設定する場合あり）
CRON_SECRET=your-random-cron-secret
